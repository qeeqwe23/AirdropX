<?xml version="1.0"?>
<!--
  JSBSim 货物弹道模型：300kg 空投货物（无伞）
  用途：蒙特卡洛落点散布仿真，每次样本独立运行此模型直到落地
  物理假设：
    - 货物为刚体箱体，无升力，仅有阻力
    - 参考面积：0.5 m^2（约 0.7m x 0.7m 正方形截面）
    - 阻力系数 CD=1.0（钝体箱形，经验值）
    - 无推进系统，无控制面
    - 落地条件：h_agl <= 0
  坐标系：JSBSim 标准体轴系，x 向前，z 向下
-->
<fdm_config name="Cargo300kg" version="2.0" release="ALPHA"
   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
   xsi:noNamespaceSchemaLocation="http://jsbsim.sourceforge.net/JSBSim.xsd">

  <fileheader>
    <description>300kg Cargo Box - Airdrop Ballistic Model (no parachute)</description>
    <version>1.0</version>
  </fileheader>

  <!-- 几何参数：以货物质心为参考点 -->
  <metrics>
    <!-- 参考面积：0.5 m^2 = 5.382 ft^2（箱体正面投影面积） -->
    <wingarea  unit="FT2">  5.382 </wingarea>
    <!-- 参考长度（弦长）：0.7 m = 2.297 ft -->
    <wingspan  unit="FT" >  2.297 </wingspan>
    <chord     unit="FT" >  2.297 </chord>
    <!-- 水平/垂直尾翼面积设为 0（无尾翼） -->
    <htailarea unit="FT2">  0.0 </htailarea>
    <htailarm  unit="FT" >  0.0 </htailarm>
    <vtailarea unit="FT2">  0.0 </vtailarea>
    <vtailarm  unit="FT" >  0.0 </vtailarm>
    <!-- 气动参考点：质心处 -->
    <location name="AERORP" unit="IN">
      <x> 0.0 </x>
      <y> 0.0 </y>
      <z> 0.0 </z>
    </location>
    <location name="EYEPOINT" unit="IN">
      <x> 0.0 </x>
      <y> 0.0 </y>
      <z> 0.0 </z>
    </location>
    <location name="VRP" unit="IN">
      <x> 0.0 </x>
      <y> 0.0 </y>
      <z> 0.0 </z>
    </location>
  </metrics>

  <!-- 质量与惯量：300kg 货物箱体 -->
  <mass_balance>
    <!-- 300 kg = 661.386 lbs -->
    <emptywt unit="LBS"> 661.386 </emptywt>
    <!-- 转动惯量：假设均匀正方体 0.7m x 0.7m x 0.7m
         Ixx = Iyy = Izz = m*(a^2+b^2)/12 = 300*(0.49+0.49)/12 = 24.5 kg*m^2 = 18.07 slug*ft^2 -->
    <ixx unit="SLUG*FT2">  18.07 </ixx>
    <iyy unit="SLUG*FT2">  18.07 </iyy>
    <izz unit="SLUG*FT2">  18.07 </izz>
    <!-- 重心在几何中心 -->
    <location name="CG" unit="IN">
      <x> 0.0 </x>
      <y> 0.0 </y>
      <z> 0.0 </z>
    </location>
  </mass_balance>

  <!-- 地面接触：单点接触（底部中心），用于落地检测 -->
  <ground_reactions>
    <contact type="STRUCTURE" name="BOTTOM">
      <location unit="IN">
        <x>  0.0 </x>
        <y>  0.0 </y>
        <!-- 箱体底部：z = +13.78 in（向下 0.35m） -->
        <z> 13.78 </z>
      </location>
      <static_friction>  0.80 </static_friction>
      <dynamic_friction> 0.60 </dynamic_friction>
      <spring_coeff  unit="LBS/FT">     5000.0 </spring_coeff>
      <damping_coeff unit="LBS/FT/SEC"> 2000.0 </damping_coeff>
    </contact>
  </ground_reactions>

  <!-- 气动力：仅阻力，无升力，无力矩 -->
  <aerodynamics>
    <!-- 升力轴：无升力（货物箱体） -->
    <axis name="LIFT">
      <!-- 升力系数 CL = 0 -->
    </axis>

    <!-- 阻力轴：CD = 1.0（钝体箱形经验值） -->
    <axis name="DRAG">
      <function name="aero/force/Drag_body">
        <description>Drag of cargo box body (CD=1.0, Sref=0.5m^2)</description>
        <product>
          <property>aero/qbar-psf</property>
          <property>metrics/Sw-sqft</property>
          <!-- CD = 1.0，固定值 -->
          <value> 1.0 </value>
        </product>
      </function>
    </axis>

    <!-- 侧力轴：无侧力 -->
    <axis name="SIDE">
    </axis>

    <!-- 滚转力矩：无 -->
    <axis name="ROLL">
    </axis>

    <!-- 俯仰力矩：无 -->
    <axis name="PITCH">
    </axis>

    <!-- 偏航力矩：无 -->
    <axis name="YAW">
    </axis>
  </aerodynamics>

</fdm_config>
